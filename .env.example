# ─── Frontend (Vite — VITE_ prefix exposes to browser) ─────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# ─── Supabase Edge Functions (set in Supabase project secrets) ─────────────────
# Automatically injected by Supabase — do NOT put these in .env.local:
# SUPABASE_URL            (same as VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY

# ─── Stripe ─────────────────────────────────────────────────────────────────────
# Set in Supabase project secrets (supabase secrets set KEY=value)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."   # Stripe Price ID for the Starter plan
STRIPE_PRICE_PREMIUM="price_..."   # Stripe Price ID for the Premium plan

# ─── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL_INSIGHTS="gpt-4o-mini"             # Model for insight generation
OPENAI_MODEL_NEWSLETTER_EXTRACTION="gpt-4o-mini" # Model for newsletter extraction
OPENAI_MODEL_META_AD_ANALYSIS="gpt-4o-mini"     # Model for Meta ad analysis

# ─── Google OAuth (Gmail integration) ───────────────────────────────────────────
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ─── Meta Ads (optional — feature is in beta) ───────────────────────────────────
META_ACCESS_TOKEN="your-meta-api-token"

# ─── App / CORS ─────────────────────────────────────────────────────────────────
APP_URL="https://your-app.com"
ALLOWED_APP_ORIGINS="https://your-app.com,https://www.your-app.com"  # comma-separated

# ─── Platform admin access ──────────────────────────────────────────────────────
PLATFORM_ADMIN_EMAILS="admin@yourdomain.com"    # comma-separated list
